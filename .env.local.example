# 📄 路径: .env.local.example

# Vercel KV 配置
KV_URL=your_kv_url
KV_REST_API_TOKEN=your_kv_rest_api_token

# Cron 任务密钥
CRON_SECRET=your_cron_secret

# Vercel 项目 URL
VERCEL_URL=your_vercel_url

# 获取指引：
# 1. KV_URL 和 KV_REST_API_TOKEN：在 Vercel 控制台创建 KV 数据库后获取
# 2. CRON_SECRET：自己设置一个随机字符串，用于验证 Cron 任务
# 3. VERCEL_URL：部署到 Vercel 后自动生成，本地开发时可设置为 localhost:3000